datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Match {
  id              String   @id
  competitionId   String
  seasonId        String
  stageId         String?
  groupId         String?
  groupName       String?
  stageName       String?
  homeTeam        String?
  homeFlag        String?
  awayTeam        String?
  awayFlag        String?
  homeCode        String?
  awayCode        String?
  date            DateTime
  round           Int?
  stadium         String?
  city            String?
  referee         String?
  attendance      String?
  status          Int
  homeScore       Int?
  awayScore       Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  manuallyAdjusted Boolean  @default(false)
  broadcasts      Broadcast[]

  @@index([competitionId, status])
  @@index([competitionId, date])
  @@index([competitionId, groupName])
  @@index([status])
  @@index([date])
  @@index([homeCode])
  @@index([awayCode])
  @@index([manuallyAdjusted])
}

model Broadcast {
  id        Int    @id @default(autoincrement())
  matchId   String
  channelId String?
  name      String
  logo      String?
  url       String?
  language  String?
  match     Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
}

model Standing {
  id            Int    @id @default(autoincrement())
  competitionId String @default("wc2026")
  seasonId      String @default("285023")
  groupId       String
  groupName     String
  teamId        String
  teamName      String
  teamCode      String?
  badge         String?
  position      Int
  played        Int
  wins          Int
  draws         Int
  losses        Int
  goalsFor      Int
  goalsAgainst  Int
  goalDifference Int
  points        Int
  updatedAt     DateTime @updatedAt

  @@unique([competitionId, seasonId, teamId])
  @@index([competitionId, seasonId])
  @@index([competitionId, groupName])
  @@index([teamCode])
  @@index([position])
}
