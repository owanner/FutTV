datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Match {

  // ID oficial FIFA
  id String @id

  competitionId String

  seasonId String

  stageId String

  groupId String?

  groupName String?

  stageName String?

  homeTeam String?

  homeFlag String?

  awayTeam String?

  awayFlag String?

  homeCode String?

  awayCode String?

  date DateTime

  stadium String?

  city String?

  referee String?

  attendance String?

  status Int

  homeScore Int?

  awayScore Int?

  createdAt DateTime @default(now())

  manuallyAdjusted Boolean @default(false)

  broadcasts Broadcast[]
}

model Broadcast {

  id Int @id @default(autoincrement())

  matchId String

  channelId String?

  name String

  logo String?

  url String?

  language String?

  match Match @relation(fields: [matchId], references: [id])
}

model Standing {

  id Int @id @default(autoincrement())

  competitionId String @default("wc2026")

  seasonId String @default("285023")

  groupId String

  groupName String

  teamId String

  teamName String

  teamCode String?

  badge String?

  position Int

  played Int

  wins Int

  draws Int

  losses Int

  goalsFor Int

  goalsAgainst Int

  goalDifference Int

  points Int

  updatedAt DateTime @updatedAt

  @@unique([competitionId, seasonId, teamId])
}

model Stage {

  id String @id

  seasonId String

  competitionId String

  name String

  sequence Int

  startDate DateTime

  endDate DateTime
}
